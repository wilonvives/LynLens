{
  "name": "@lynlens/mcp-server",
  "version": "0.1.0",
  "description": "LynLens MCP Server - exposes the Core Engine to Claude/Cursor via MCP protocol",
  "type": "module",
  "bin": {
    "lynlens-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lynlens/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  }
}
