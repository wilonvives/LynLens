{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/renderer",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
